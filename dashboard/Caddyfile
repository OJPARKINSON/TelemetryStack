:8080

header {
	X-Frame-Options "SAMEORIGIN"
	X-XSS-Protection "1; mode=block"
	X-Content-Type-Options "nosniff"
}

# Redirect bare /dashboard to /dashboard/
@dashboard-bare path /dashboard
handle @dashboard-bare {
	redir /dashboard/ permanent
}

# Handle /dashboard/* — strip prefix and serve static files
handle_path /dashboard/* {
	root * /app/www
	try_files {path} {path}/ /index.html
	file_server
}

# Fallback: serve at root (for when Traefik has already stripped the prefix)
handle {
	root * /app/www
	try_files {path} {path}/ /index.html
	file_server
}
